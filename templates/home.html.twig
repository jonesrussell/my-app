{% extends 'layouts/base.html.twig' %}

{% block title %}{{ site_name|default('Waaseyaa') }} | Starter Site{% endblock %}

{% block body %}
  {% set hero = demo.hero|default({}) %}
  <section class="hero" aria-labelledby="home-title">
    <div class="hero__content">
      <p class="eyebrow">{{ hero.eyebrow|default('Fresh Waaseyaa starter') }}</p>
      <h1 id="home-title">{{ hero.title|default('A clean public site for structured content.') }}</h1>
      <p class="hero__lede">{{ hero.subtitle|default('Publish once, then serve people, APIs, and agents from the same content model.') }}</p>
      <div class="hero__actions" aria-label="Primary actions">
        <a class="button" href="{{ hero.primaryCta.href|default('/story/1') }}">{{ hero.primaryCta.label|default('Read a story') }}</a>
        <a class="button button--secondary" href="{{ hero.secondaryCta.href|default('/admin/') }}">{{ hero.secondaryCta.label|default('Open admin') }}</a>
      </div>
    </div>
  </section>

  <section class="section section--compact" aria-labelledby="search-title">
    <div class="search-panel">
      <div>
        <p class="eyebrow">Search ready</p>
        <h2 id="search-title">Find public content from one simple surface.</h2>
      </div>
      <form class="site-search" action="/api/story" method="get" role="search">
        <label for="site-search-query">Search content</label>
        <div class="site-search__row">
          <input id="site-search-query" name="filter[search]" type="search" placeholder="Try stories, people, places">
          <button class="button" type="submit">Search</button>
        </div>
      </form>
    </div>
  </section>

  <section class="section" aria-labelledby="starter-title">
    <div class="section__header">
      <p class="eyebrow">What is ready</p>
      <h2 id="starter-title">A starter surface with the boring parts already handled.</h2>
    </div>
    <div class="card-grid">
      {% for feature in demo.features|default([]) %}
        {% include 'partials/_card.html.twig' with {
          title: feature.title,
          body: feature.body,
          href: feature.href,
          cta: feature.cta
        } only %}
      {% endfor %}
    </div>
  </section>

  <section class="section section--split" aria-labelledby="latest-title">
    <div class="section__header">
      <p class="eyebrow">Latest content</p>
      <h2 id="latest-title">A feed-shaped space for stories, posts, or pages.</h2>
    </div>
    <div class="feed-list">
      {% for item in demo.latest|default([]) %}
        <article class="feed-item">
          <p>{{ item.type }}</p>
          <h3><a href="{{ item.href }}">{{ item.title }}</a></h3>
        </article>
      {% endfor %}
    </div>
  </section>

  {% set cta = demo.cta|default({}) %}
  <section class="section" aria-labelledby="home-cta-title">
    <div class="cta-band">
      <div>
        <p class="eyebrow">Safe to replace</p>
        <h2 id="home-cta-title">{{ cta.title|default('Ready to make it yours?') }}</h2>
        <p>{{ cta.body|default('Replace this fallback page with editable home content when the site is ready.') }}</p>
      </div>
      <div class="hero__actions">
        <a class="button" href="{{ cta.primaryCta.href|default('/admin/') }}">{{ cta.primaryCta.label|default('Open admin') }}</a>
        <a class="button button--secondary" href="{{ cta.secondaryCta.href|default('/theme/brand.css') }}">{{ cta.secondaryCta.label|default('Inspect brand') }}</a>
      </div>
    </div>
  </section>
{% endblock %}
