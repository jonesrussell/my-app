{% set nav = primary_nav|default([
  { label: 'Home', href: '/' },
  { label: 'Stories', href: '/admin/story' },
  { label: 'Admin', href: '/admin/' }
]) %}

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="{{ site_name|default('Waaseyaa') }} home">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">{{ site_name|default('Waaseyaa') }}</span>
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      {% for item in nav %}
        <a href="{{ item.href }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
</header>
