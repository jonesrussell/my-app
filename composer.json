{
    "name": "waaseyaa/waaseyaa",
    "description": "Waaseyaa CMS project skeleton",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.5",
        "symfony/dotenv": "^8.0",
        "waaseyaa/framework": "^0.1.0-alpha.239"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "scripts": {
        "audit-site": "./bin/maintenance/waaseyaa-audit-site",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/waaseyaa dev"
        ],
        "regen-lock": "@composer update 'waaseyaa/*' --no-plugins --no-install --no-scripts",
        "serve:franken": "frankenphp php-server --root public --listen 127.0.0.1:8080",
        "post-create-project-cmd": [
            "php bin/post-create-setup.php"
        ]
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ],
            "prepend-repositories": true
        },
        "waaseyaa": {
            "providers": [
                "App\\Provider\\AppServiceProvider",
                "App\\Provider\\StoryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
